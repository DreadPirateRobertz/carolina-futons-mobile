# Carolina Futons Mobile — Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ──── Required ────────────────────────────────────────────

# Stripe publishable key (app will crash on launch without this)
# Get from: https://dashboard.stripe.com/apikeys
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here

# Wix SDK client ID (required for Wix auth)
# Get from: Wix Dashboard → OAuth Apps
EXPO_PUBLIC_WIX_CLIENT_ID=your_wix_client_id

# Wix REST API key and site ID (required for product catalog)
# API key: https://www.wix.com/my-account/site-selector
# Site ID: Wix Dashboard → Settings → Advanced
EXPO_PUBLIC_WIX_API_KEY=your_wix_api_key
EXPO_PUBLIC_WIX_SITE_ID=your_wix_site_id

# Google OAuth client IDs (required for native Google Sign-In)
# Create at: https://console.cloud.google.com/apis/credentials
# Web client ID is required; iOS/Android are optional but recommended
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your_google_web_client_id
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your_google_ios_client_id
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=your_google_android_client_id

# ──── Crash Reporting ─────────────────────────────────────

# Sentry DSN for crash reporting (optional — logs to console if omitted)
# Get from: https://sentry.io → Project Settings → Client Keys (DSN)
# EXPO_PUBLIC_SENTRY_DSN=https://your-key@sentry.io/your-project-id

# Sentry auth token for source map upload during EAS production builds
# Get from: https://sentry.io → Settings → Auth Tokens → Create New Token
# Required scopes: project:releases, org:read
# Also set as EAS secret: eas secret:create --name SENTRY_AUTH_TOKEN --value <token>
# SENTRY_AUTH_TOKEN=sntrys_your_token_here

# ──── Analytics ───────────────────────────────────────────

# Mixpanel token (optional — Firebase Analytics is enabled by default)
# Get from: https://mixpanel.com → Project Settings → Token
# EXPO_PUBLIC_MIXPANEL_TOKEN=your_mixpanel_token

# ──── In-App Purchases (RevenueCat) ──────────────────────

# RevenueCat API keys (optional — purchases disabled if omitted)
# Get from: https://app.revenuecat.com → Project → API Keys
# EXPO_PUBLIC_REVENUECAT_IOS_KEY=appl_your_ios_key_here
# EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=goog_your_android_key_here

# ──── Optional ────────────────────────────────────────────

# Wix API base URL (default: https://www.wixapis.com)
# EXPO_PUBLIC_WIX_BASE_URL=https://www.wixapis.com

# ──── 3D Pipeline (scripts/pipeline only) ─────────────────

# Tripo AI API key (for 3D model generation pipeline)
# TRIPO_API_KEY=your_tripo_key

# Meshy AI API key (for 3D model generation pipeline)
# MESHY_API_KEY=your_meshy_key
