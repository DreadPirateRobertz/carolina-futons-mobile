{
  "name": "carolina-futons-mobile",
  "version": "0.1.0",
  "private": true,
  "main": "expo/AppEntry",
  "scripts": {
    "start": "expo start",
    "ios": "expo start --ios",
    "android": "expo start --android",
    "web": "expo start --web",
    "test": "npx jest",
    "test:watch": "npx jest --watch",
    "test:coverage": "npx jest --coverage",
    "lint": "eslint src/ --ext .ts,.tsx",
    "format": "prettier --write 'src/**/*.{ts,tsx}'",
    "typecheck": "tsc --noEmit",
    "pipeline:generate": "npx tsx scripts/pipeline/generate.ts",
    "pipeline:convert": "npx tsx scripts/pipeline/convert.ts",
    "pipeline:validate": "npx tsx scripts/pipeline/validate.ts --dir scripts/pipeline/output",
    "pipeline:sync": "npx tsx scripts/pipeline/sync-catalog.ts",
    "pipeline:all": "npm run pipeline:generate && npm run pipeline:convert && npm run pipeline:validate && npm run pipeline:sync",
    "e2e:build:ios": "detox build --configuration ios.sim.debug",
    "e2e:build:android": "detox build --configuration android.emu.debug",
    "e2e:test:ios": "detox test --configuration ios.sim.debug",
    "e2e:test:android": "detox test --configuration android.emu.debug",
    "e2e:prebuild": "npx expo prebuild --clean",
    "screenshots": "bash scripts/take-screenshots.sh all",
    "screenshots:ios": "bash scripts/take-screenshots.sh ios",
    "screenshots:android": "bash scripts/take-screenshots.sh android",
    "catalog:sync": "npx tsx scripts/sync-3d-catalog.ts",
    "catalog:check": "npx tsx scripts/sync-3d-catalog.ts --check"
  },
  "dependencies": {
    "@expo-google-fonts/playfair-display": "^0.4.2",
    "@expo-google-fonts/source-sans-3": "^0.4.1",
    "@expo/metro-runtime": "~4.0.1",
    "@react-native-async-storage/async-storage": "1.23.1",
    "@react-native-community/netinfo": "11.4.1",
    "@react-navigation/bottom-tabs": "^7.0.0",
    "@react-navigation/native": "^7.0.0",
    "@react-navigation/native-stack": "^7.0.0",
    "@sentry/react-native": "~6.10.0",
    "@stripe/stripe-react-native": "0.38.6",
    "@wix/members": "^1.0.430",
    "@wix/sdk": "^1.21.3",
    "expo": "~52.0.0",
    "expo-apple-authentication": "~7.1.3",
    "expo-asset": "~11.0.5",
    "expo-blur": "~14.0.3",
    "expo-camera": "~16.0.18",
    "expo-constants": "~17.0.8",
    "expo-crypto": "~14.0.2",
    "expo-device": "~7.0.3",
    "expo-file-system": "~18.0.12",
    "expo-font": "~13.0.4",
    "expo-haptics": "~14.0.1",
    "expo-image": "~2.0.7",
    "expo-image-picker": "~16.0.6",
    "expo-linking": "~7.0.5",
    "expo-local-authentication": "^55.0.8",
    "expo-media-library": "~17.0.6",
    "expo-notifications": "~0.29.14",
    "expo-secure-store": "~14.0.1",
    "expo-sharing": "~13.0.1",
    "expo-splash-screen": "~0.29.24",
    "expo-status-bar": "~2.0.0",
    "expo-store-review": "~8.0.1",
    "expo-web-browser": "~14.0.2",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-native": "^0.76.9",
    "react-native-gesture-handler": "~2.20.0",
    "react-native-reanimated": "~3.16.0",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "react-native-svg": "15.8.0",
    "react-native-purchases": "^9.11.2",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-view-shot": "~4.0.3",
    "react-native-web": "~0.19.13"
  },
  "devDependencies": {
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^12.4.0",
    "@types/detox": "^17.14.3",
    "@types/jest": "^30.0.0",
    "@types/react": "~18.3.0",
    "@types/react-test-renderer": "^18.3.0",
    "detox": "^20.47.0",
    "eslint": "^8.57.0",
    "eslint-config-expo": "^8.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.0",
    "expo-auth-session": "^55.0.7",
    "jest": "^29.7.0",
    "jest-circus": "^30.2.0",
    "jest-expo": "~52.0.0",
    "prettier": "^3.2.0",
    "react-test-renderer": "18.3.1",
    "typescript": "~5.3.3"
  }
}
