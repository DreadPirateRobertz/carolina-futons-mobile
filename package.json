{
  "name": "carolina-futons-mobile",
  "version": "0.1.0",
  "private": true,
  "main": "App.tsx",
  "scripts": {
    "start": "expo start",
    "ios": "expo start --ios",
    "android": "expo start --android",
    "web": "expo start --web",
    "test": "npx jest",
    "test:watch": "npx jest --watch",
    "test:coverage": "npx jest --coverage",
    "lint": "eslint src/ --ext .ts,.tsx",
    "format": "prettier --write 'src/**/*.{ts,tsx}'",
    "typecheck": "tsc --noEmit",
    "pipeline:generate": "npx tsx scripts/pipeline/generate.ts",
    "pipeline:convert": "npx tsx scripts/pipeline/convert.ts",
    "pipeline:validate": "npx tsx scripts/pipeline/validate.ts --dir scripts/pipeline/output",
    "pipeline:sync": "npx tsx scripts/pipeline/sync-catalog.ts",
    "pipeline:all": "npm run pipeline:generate && npm run pipeline:convert && npm run pipeline:validate && npm run pipeline:sync"
  },
  "dependencies": {
    "@expo-google-fonts/playfair-display": "^0.4.2",
    "@expo-google-fonts/source-sans-3": "^0.4.1",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-navigation/bottom-tabs": "^7.0.0",
    "@react-navigation/native": "^7.0.0",
    "@react-navigation/native-stack": "^7.0.0",
    "expo": "~52.0.0",
    "expo-camera": "~16.0.18",
    "expo-file-system": "~18.0.12",
    "expo-font": "~13.0.4",
    "expo-haptics": "~14.0.1",
    "expo-media-library": "~17.0.6",
    "expo-sharing": "~13.0.1",
    "expo-splash-screen": "~0.29.24",
    "expo-status-bar": "~2.0.0",
    "react": "18.3.1",
    "react-native": "0.76.7",
    "react-native-gesture-handler": "~2.20.0",
    "react-native-reanimated": "~3.16.0",
    "react-native-safe-area-context": "~4.14.0",
    "react-native-screens": "~4.4.0",
    "react-native-view-shot": "~4.0.3"
  },
  "devDependencies": {
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^12.4.0",
    "@types/jest": "^30.0.0",
    "@types/react": "~18.3.0",
    "@types/react-test-renderer": "^18.3.0",
    "eslint": "^8.57.0",
    "eslint-config-expo": "^8.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.0",
    "jest": "^29.7.0",
    "jest-expo": "~52.0.0",
    "prettier": "^3.2.0",
    "react-test-renderer": "18.3.1",
    "typescript": "~5.3.3"
  }
}
